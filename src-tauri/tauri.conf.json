{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QuickLaunch",
  "version": "1.0.0",
  "identifier": "com.ani9085.quicklaunch",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "QuickLaunch",
        "width": 560,
        "height": 520,
        "minWidth": 300,
        "minHeight": 280,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
