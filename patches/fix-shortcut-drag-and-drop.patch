From 7188169a58e057a868c6022c1431962b54baede9 Mon Sep 17 00:00:00 2001
From: openclaw-agent <openclaw-agent@users.noreply.github.com>
Date: Mon, 22 Jun 2026 12:42:42 +0900
Subject: [PATCH] Fix shortcut drag and drop

---
 src/renderer.js | 73 +++++++++++++++++++++++++++++++++++++++----------
 1 file changed, 58 insertions(+), 15 deletions(-)

diff --git a/src/renderer.js b/src/renderer.js
index fe17ffe..fb9e962 100644
--- a/src/renderer.js
+++ b/src/renderer.js
@@ -39,6 +39,7 @@ let editingSlot = null; // 편집 중인 슬롯 인덱스
 let draft = null; // 편집 모달 임시 데이터
 let dragState = null;
 let suppressTileClick = false;
+let suppressDeckTabClick = false;
 const SAFE_ITEM_TYPES = new Set(["url", "app", "file", "folder", "hotkey"]);
 const DEFAULT_ICON = "📁";
 const DEFAULT_COLOR = "#2d3748";
@@ -228,14 +229,21 @@ function renderDeckTabs() {
     b.className = "deck-tab" + (d.id === state.activeDeckId ? " active" : "");
     b.textContent = d.name;
     b.onclick = () => {
+      if (suppressDeckTabClick) return;
       state.activeDeckId = d.id;
       persist();
       renderAll();
       fitWindow();
     };
     if (editMode) {
+      b.ondragenter = (e) => {
+        const payload = currentDragPayload(e);
+        if (!payload || payload.deckId === d.id) return;
+        e.preventDefault();
+      };
       b.ondragover = (e) => {
-        if (!dragState || dragState.deckId === d.id) return;
+        const payload = currentDragPayload(e);
+        if (!payload || payload.deckId === d.id) return;
         e.preventDefault();
         e.dataTransfer.dropEffect = "move";
         b.classList.add("drop-target");
@@ -243,8 +251,10 @@ function renderDeckTabs() {
       b.ondragleave = () => b.classList.remove("drop-target");
       b.ondrop = (e) => {
         e.preventDefault();
+        e.stopPropagation();
+        suppressDeckTabClick = true;
         b.classList.remove("drop-target");
-        moveDraggedToDeck(d.id);
+        moveDraggedToDeck(d.id, currentDragPayload(e));
       };
     }
     wrap.appendChild(b);
@@ -338,11 +348,40 @@ function clearDropTargets() {
   $$(".drop-target").forEach((el) => el.classList.remove("drop-target"));
 }
 
+function dragPayloadFromEvent(e) {
+  const raw =
+    e?.dataTransfer?.getData("application/x-quicklaunch-tile") ||
+    e?.dataTransfer?.getData("text/plain");
+  if (!raw) return null;
+
+  try {
+    const parsed = JSON.parse(raw);
+    if (typeof parsed.deckId === "string" && Number.isInteger(parsed.slot)) {
+      return parsed;
+    }
+  } catch (_) {
+    const m = /^(.+):(\d+)$/.exec(raw);
+    if (m) return { deckId: m[1], slot: Number(m[2]) };
+  }
+
+  return null;
+}
+
+function currentDragPayload(e) {
+  return dragState || dragPayloadFromEvent(e);
+}
+
 function bindTileDrag(tile, deckId, slot, hasItem) {
   if (!editMode) return;
 
+  tile.ondragenter = (e) => {
+    const payload = currentDragPayload(e);
+    if (!payload || payload.deckId !== deckId) return;
+    e.preventDefault();
+  };
   tile.ondragover = (e) => {
-    if (!dragState || dragState.deckId !== deckId) return;
+    const payload = currentDragPayload(e);
+    if (!payload || payload.deckId !== deckId) return;
     e.preventDefault();
     e.dataTransfer.dropEffect = "move";
     tile.classList.add("drop-target");
@@ -350,8 +389,9 @@ function bindTileDrag(tile, deckId, slot, hasItem) {
   tile.ondragleave = () => tile.classList.remove("drop-target");
   tile.ondrop = (e) => {
     e.preventDefault();
+    e.stopPropagation();
     tile.classList.remove("drop-target");
-    moveDraggedToSlot(slot);
+    moveDraggedToSlot(slot, currentDragPayload(e));
   };
 
   if (!hasItem) return;
@@ -359,28 +399,31 @@ function bindTileDrag(tile, deckId, slot, hasItem) {
   tile.draggable = true;
   tile.classList.add("draggable");
   tile.ondragstart = (e) => {
-    dragState = { deckId, slot };
+    const payload = { deckId, slot };
+    dragState = payload;
     suppressTileClick = true;
     tile.classList.add("dragging");
     e.dataTransfer.effectAllowed = "move";
+    e.dataTransfer.setData("application/x-quicklaunch-tile", JSON.stringify(payload));
     e.dataTransfer.setData("text/plain", `${deckId}:${slot}`);
   };
   tile.ondragend = () => {
     tile.classList.remove("dragging");
     clearDropTargets();
-    dragState = null;
     setTimeout(() => {
+      dragState = null;
       suppressTileClick = false;
+      suppressDeckTabClick = false;
     }, 0);
   };
 }
 
-function moveDraggedToSlot(targetSlot) {
-  if (!dragState) return;
-  const deck = state.decks.find((d) => d.id === dragState.deckId);
+function moveDraggedToSlot(targetSlot, payload = dragState) {
+  if (!payload) return;
+  const deck = state.decks.find((d) => d.id === payload.deckId);
   if (!deck || deck.id !== state.activeDeckId) return;
 
-  const sourceSlot = dragState.slot;
+  const sourceSlot = payload.slot;
   if (sourceSlot === targetSlot) return;
 
   const sourceItem = deck.items[sourceSlot];
@@ -396,14 +439,14 @@ function moveDraggedToSlot(targetSlot) {
   setStatus(targetItem ? "위치 교환됨" : "위치 이동됨");
 }
 
-function moveDraggedToDeck(targetDeckId) {
-  if (!dragState || dragState.deckId === targetDeckId) return;
+function moveDraggedToDeck(targetDeckId, payload = dragState) {
+  if (!payload || payload.deckId === targetDeckId) return;
 
-  const sourceDeck = state.decks.find((d) => d.id === dragState.deckId);
+  const sourceDeck = state.decks.find((d) => d.id === payload.deckId);
   const targetDeck = state.decks.find((d) => d.id === targetDeckId);
   if (!sourceDeck || !targetDeck) return;
 
-  const item = sourceDeck.items[dragState.slot];
+  const item = sourceDeck.items[payload.slot];
   if (!item) return;
 
   const targetSlot = firstEmptySlot(targetDeck);
@@ -413,7 +456,7 @@ function moveDraggedToDeck(targetDeckId) {
   }
 
   targetDeck.items[targetSlot] = item;
-  delete sourceDeck.items[dragState.slot];
+  delete sourceDeck.items[payload.slot];
   state.activeDeckId = targetDeck.id;
 
   persist();
-- 
2.54.0.windows.1
